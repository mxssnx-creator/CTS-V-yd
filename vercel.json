{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/server-continuity",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/sync-live-positions",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "app/api/**": {
      "maxDuration": 30
    },
    "app/api/cron/**": {
      "maxDuration": 60
    },
    "app/api/engine/**": {
      "maxDuration": 60
    },
    "app/api/connections/*/progression/**": {
      "maxDuration": 45
    }
  }
}
